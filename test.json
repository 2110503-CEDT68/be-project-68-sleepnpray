      "name": "REGISTER",
      "item": [
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "pm.test(\"User registered successfully\", function () {\r",
                  "    pm.expect(json).to.have.property(\"success\", true);\r",
                  "    pm.expect(json).to.have.property(\"token\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"TOKEN\", json.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = pm.variables.replaceIn(\"{{$randomEmail}}\");\r",
                  "const password = pm.variables.replaceIn(\"{{$randomPassword}}\");\r",
                  "const username = pm.variables.replaceIn(\"{{$randomUserName}}\");\r",
                  "\r",
                  "pm.environment.set(\"demo_email\", email);\r",
                  "pm.environment.set(\"demo_password\", password);\r",
                  "pm.environment.set(\"demo_username\", username);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
