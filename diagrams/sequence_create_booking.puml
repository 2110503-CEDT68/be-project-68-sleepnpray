@startuml
title Sequence — Create Booking (Authenticated User/Admin)

participant "Client/User" as client
participant "API Server" as server
participant "AuthMiddleware" as authMW
participant "BookingsCtrl" as bookingCtrl
participant "Campground DB" as campDB
participant "Booking DB" as bookingDB

client -> server: POST /campgrounds/{campgroundId}/bookings\nAuthorization: Bearer {token}\nBody: {startDate, nights}
activate server

server -> authMW: protect(req, res, next)
activate authMW
authMW -> authMW: verify JWT + load user
authMW --> server: req.user populated
deactivate authMW

server -> authMW: authorize('admin', 'user')
activate authMW
alt Role valid
  authMW --> server: pass
else Invalid role
  authMW --> server: 403
end
deactivate authMW

server -> bookingCtrl: addBooking(req, res)
activate bookingCtrl
bookingCtrl -> bookingCtrl: validate nights (1-3)
bookingCtrl -> campDB: Campground.findById(campgroundId)
activate campDB
campDB --> bookingCtrl: campground or null
deactivate campDB

alt Campground found
  bookingCtrl -> bookingDB: Booking.create(...)
  activate bookingDB
  bookingDB --> bookingCtrl: newBooking
  deactivate bookingDB
else Not found
  bookingCtrl -> bookingCtrl: prepare 404 response
end

bookingCtrl --> server: 201 or 404
deactivate bookingCtrl

server --> client: response
deactivate server

@enduml
